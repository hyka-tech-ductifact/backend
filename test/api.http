# API Test Suite
# Use with REST Client plugin in VS Code (humao.rest-client)
# Make sure the server is running: make dev or make app-start
#
# Workflow: Register → Login → copy access_token → use protected endpoints

# =============================================================================
# CONFIGURATION
# =============================================================================

@baseUrl = http://localhost:8080/v1
@token = <paste-access-token-here>

# =============================================================================
# HEALTH, METRICS & DOCS (public)
# =============================================================================

### Health Check
GET http://localhost:8080/health

### Prometheus Metrics
GET http://localhost:8080/metrics

### Swagger UI (API documentation)
GET http://localhost:8080/docs

### Raw OpenAPI spec
GET http://localhost:8080/docs/openapi.yaml

# =============================================================================
# AUTH (public)
# =============================================================================

### Register a new user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Juan García",
  "email": "juan@example.com",
  "password": "securepass123"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "juan@example.com",
  "password": "securepass123"
}

# =============================================================================
# AUTH VALIDATION (public)
# =============================================================================

### Register — missing name → 400
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "securepass123"
}

### Register — invalid email → 400
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test User",
  "email": "invalid-email",
  "password": "securepass123"
}

### Register — password too short → 400
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test User",
  "email": "test@example.com",
  "password": "short"
}

### Login — wrong password → 401
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "juan@example.com",
  "password": "wrongpassword"
}

# =============================================================================
# REFRESH TOKEN (public — uses refresh_token from register/login response)
# =============================================================================

@refreshToken = <paste-refresh-token-here>

### Refresh access token — valid → 200
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Refresh — missing body → 400
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{}

### Refresh — invalid token → 401
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refresh_token": "invalid-token"
}

# =============================================================================
# USER PROFILE (protected — requires Bearer token)
# =============================================================================

### Get my profile
GET {{baseUrl}}/users/me
Authorization: Bearer {{token}}

### Update my profile
PUT {{baseUrl}}/users/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Juan Updated"
}

### Update my email
PUT {{baseUrl}}/users/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "juan.new@example.com"
}

### Unauthorized — no token → 401
GET {{baseUrl}}/users/me

# =============================================================================
# CLIENTS (protected — requires Bearer token)
# =============================================================================

### Create a client (all fields)
POST {{baseUrl}}/clients
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Acme Corp",
  "phone": "+34 600 111 222",
  "email": "acme@example.com",
  "description": "Main client for project management"
}

### Create a client (minimal — name only)
POST {{baseUrl}}/clients
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Minimal Client"
}

### List my clients
GET {{baseUrl}}/clients
Authorization: Bearer {{token}}

### Get a client by ID (replace with actual UUID)
GET {{baseUrl}}/clients/{{client_id}}
Authorization: Bearer {{token}}

### Update a client (all fields)
PUT {{baseUrl}}/clients/{{client_id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Acme Corp Updated",
  "phone": "+34 600 999 888",
  "email": "acme.updated@example.com",
  "description": "Updated description"
}

### Update a client (partial — phone only)
PUT {{baseUrl}}/clients/{{client_id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "phone": "+34 600 555 666"
}

### Delete a client
DELETE {{baseUrl}}/clients/{{client_id}}
Authorization: Bearer {{token}}

# =============================================================================
# CLIENT VALIDATION (protected)
# =============================================================================

### Create client — missing name → 400
POST {{baseUrl}}/clients
Authorization: Bearer {{token}}
Content-Type: application/json

{}

### Create client — invalid phone → 400
POST {{baseUrl}}/clients
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Bad Phone Client",
  "phone": "abc"
}

### Create client — invalid email → 400
POST {{baseUrl}}/clients
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Bad Email Client",
  "email": "not-an-email"
}

### Get client — invalid UUID → 400
GET {{baseUrl}}/clients/not-a-uuid
Authorization: Bearer {{token}}

# =============================================================================
# PROJECTS (protected — requires Bearer token)
# =============================================================================

@client_id = <paste-client-uuid-here>
@project_id = <paste-project-uuid-here>

### Create a project (all fields)
POST {{baseUrl}}/clients/{{client_id}}/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Residential Tower B",
  "address": "Calle Mayor 12, Madrid",
  "manager_name": "Carlos Pérez",
  "phone": "+34 699 111 222",
  "description": "14-storey residential building, phase 1"
}

### Create a project (minimal — name only)
POST {{baseUrl}}/clients/{{client_id}}/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Minimal Project"
}

### List projects for a client
GET {{baseUrl}}/clients/{{client_id}}/projects
Authorization: Bearer {{token}}

### List projects — page 2
GET {{baseUrl}}/clients/{{client_id}}/projects?page=2&page_size=5
Authorization: Bearer {{token}}

### Get a project by ID
GET {{baseUrl}}/projects/{{project_id}}
Authorization: Bearer {{token}}

### Update a project (all fields)
PUT {{baseUrl}}/projects/{{project_id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Tower B - Phase 2",
  "address": "Avenida de la Constitución 1, Sevilla",
  "manager_name": "Ana García",
  "phone": "+34 600 999 888",
  "description": "Updated to phase 2"
}

### Update a project (partial — address only)
PUT {{baseUrl}}/projects/{{project_id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "address": "New Address 5, Barcelona"
}

### Delete a project
DELETE {{baseUrl}}/projects/{{project_id}}
Authorization: Bearer {{token}}

# =============================================================================
# PROJECT VALIDATION (protected)
# =============================================================================

### Create project — missing name → 400
POST {{baseUrl}}/clients/{{client_id}}/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{}

### Create project — invalid phone → 400
POST {{baseUrl}}/clients/{{client_id}}/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Bad Phone Project",
  "phone": "abc"
}

### Create project — non-existing client → 404
POST {{baseUrl}}/clients/00000000-0000-0000-0000-000000000000/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Orphan Project"
}

### Get project — invalid UUID → 400
GET {{baseUrl}}/projects/not-a-uuid
Authorization: Bearer {{token}}

# =============================================================================
# ORDERS (protected — requires Bearer token)
# =============================================================================

@order_id = <paste-order-uuid-here>

### Create an order (default status = pending)
POST {{baseUrl}}/projects/{{project_id}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Steel beams – lot 3",
  "description": "First batch of structural steel for floors 1-5"
}

### Create an order (with status)
POST {{baseUrl}}/projects/{{project_id}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Concrete mix – delivery 1",
  "status": "completed",
  "description": "High-strength concrete for foundation"
}

### List orders for a project
GET {{baseUrl}}/projects/{{project_id}}/orders
Authorization: Bearer {{token}}

### List orders — page 2
GET {{baseUrl}}/projects/{{project_id}}/orders?page=2&page_size=5
Authorization: Bearer {{token}}

### Get an order by ID
GET {{baseUrl}}/orders/{{order_id}}
Authorization: Bearer {{token}}

### Update an order (all fields)
PUT {{baseUrl}}/orders/{{order_id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Steel beams – lot 3 (updated)",
  "status": "completed",
  "description": "Updated description for the order"
}

### Update an order (partial — status only)
PUT {{baseUrl}}/orders/{{order_id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "completed"
}

### Delete an order
DELETE {{baseUrl}}/orders/{{order_id}}
Authorization: Bearer {{token}}

# =============================================================================
# ORDER VALIDATION (protected)
# =============================================================================

### Create order — missing title → 400
POST {{baseUrl}}/projects/{{project_id}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{}

### Create order — invalid status → 400
POST {{baseUrl}}/projects/{{project_id}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Some order",
  "status": "invalid"
}

### Create order — non-existing project → 404
POST {{baseUrl}}/projects/00000000-0000-0000-0000-000000000000/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Orphan Order"
}

### Get order — invalid UUID → 400
GET {{baseUrl}}/projects/{{project_id}}/orders/not-a-uuid
Authorization: Bearer {{token}}
