# API Test Suite
# Use with REST Client plugin in VS Code (humao.rest-client)
# Make sure the server is running: make app-watch or make docker-start
#
# Workflow: Register → Login → copy access_token → use protected endpoints

# =============================================================================
# CONFIGURATION
# =============================================================================

@baseUrl = http://localhost:8080/v1
@token = <paste-access-token-here>

# =============================================================================
# HEALTH, METRICS & DOCS (public)
# =============================================================================

### Health Check
GET http://localhost:8080/health

### Prometheus Metrics
GET http://localhost:8080/metrics

### Swagger UI (API documentation)
GET http://localhost:8080/docs

### Raw OpenAPI spec
GET http://localhost:8080/docs/openapi.yaml

# =============================================================================
# AUTH (public)
# =============================================================================

### Register a new user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Juan García",
  "email": "juan@example.com",
  "password": "securepass123"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "juan@example.com",
  "password": "securepass123"
}

# =============================================================================
# AUTH VALIDATION (public)
# =============================================================================

### Register — missing name → 400
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "securepass123"
}

### Register — invalid email → 400
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test User",
  "email": "invalid-email",
  "password": "securepass123"
}

### Register — password too short → 400
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test User",
  "email": "test@example.com",
  "password": "short"
}

### Login — wrong password → 401
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "juan@example.com",
  "password": "wrongpassword"
}

# =============================================================================
# REFRESH TOKEN (public — uses refresh_token from register/login response)
# =============================================================================

@refreshToken = <paste-refresh-token-here>

### Refresh access token — valid → 200
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Refresh — missing body → 400
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{}

### Refresh — invalid token → 401
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refresh_token": "invalid-token"
}

# =============================================================================
# USER PROFILE (protected — requires Bearer token)
# =============================================================================

### Get my profile
GET {{baseUrl}}/users/me
Authorization: Bearer {{token}}

### Update my profile
PUT {{baseUrl}}/users/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Juan Updated"
}

### Update my email
PUT {{baseUrl}}/users/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "juan.new@example.com"
}

### Unauthorized — no token → 401
GET {{baseUrl}}/users/me

# =============================================================================
# CLIENTS (protected — requires Bearer token)
# =============================================================================

### Create a client
POST {{baseUrl}}/users/me/clients
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Acme Corp"
}

### List my clients
GET {{baseUrl}}/users/me/clients
Authorization: Bearer {{token}}

### Get a client by ID (replace with actual UUID)
GET {{baseUrl}}/users/me/clients/{{client_id}}
Authorization: Bearer {{token}}

### Update a client
PUT {{baseUrl}}/users/me/clients/{{client_id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Acme Corp Updated"
}

### Delete a client
DELETE {{baseUrl}}/users/me/clients/{{client_id}}
Authorization: Bearer {{token}}

# =============================================================================
# CLIENT VALIDATION (protected)
# =============================================================================

### Create client — missing name → 400
POST {{baseUrl}}/users/me/clients
Authorization: Bearer {{token}}
Content-Type: application/json

{}

### Get client — invalid UUID → 400
GET {{baseUrl}}/users/me/clients/not-a-uuid
Authorization: Bearer {{token}}
