### Get Event by ID (replace with actual UUID from create response)
GET {{baseUrl}}/events/{{event_id}}
Content-Type: application/json

### Get Event by ID (example with UUID)
GET {{baseUrl}}/events/123e4567-e89b-12d3-a456-426614174000
Content-Type: application/json

### Get Non-existent Event
GET {{baseUrl}}/events/00000000-0000-0000-0000-000000000000
Content-Type: application/json

# =============================================================================
# EVENT VALIDATION TESTS
# =============================================================================

### Test Invalid Event Duration (end_time before start_time)
POST {{baseUrl}}/events
Content-Type: application/json

{
  "title": "La Liga: Real Madrid vs Barcelona",
  "description": "This event should fail validation due to invalid time",
  "location": "Santiago Bernabéu Stadium, Madrid",
  "start_time": "2024-06-15T21:00:00Z",
  "end_time": "2024-06-15T20:00:00Z",
  "organizer_id": "123e4567-e89b-12d3-a456-426614174000"
}

### Test Missing Required Fields
POST {{baseUrl}}/events
Content-Type: application/json

{
  "title": "World Cup Qualifier",
  "description": "Missing required fields like location, times, and organizer"
}

### Test Invalid JSON
POST {{baseUrl}}/events
Content-Type: application/json

{
  "title": "Invalid JSON",
  "description": "This should fail due to malformed JSON",
  "location": "Test Stadium",
  "start_time": "2024-06-15T15:00:00Z",
  "end_time": "2024-06-15T17:00:00Z",
  "organizer_id": "123e4567-e89b-12d3-a456-426614174000"
}

# =============================================================================
# USER ENDPOINTS (Future Implementation)
# =============================================================================

### Create User
POST {{baseUrl}}/api/v1/users
Content-Type: application/json

{
  "email": "john.doe@example.com",
  "name": "John Doe"
}

### Get User by ID
GET {{baseUrl}}/api/v1/users/{{user_id}}
Content-Type: application/json

### Get User by ID (example with UUID)
GET {{baseUrl}}/api/v1/users/123e4567-e89b-12d3-a456-426614174000
Content-Type: application/json

### Update User
PUT {{baseUrl}}/api/v1/users/{{user_id}}
Content-Type: application/json

{
  "email": "john.updated@example.com",
  "name": "John Updated"
}

### Delete User
DELETE {{baseUrl}}/api/v1/users/{{user_id}}
Content-Type: application/json

### List Users
GET {{baseUrl}}/api/v1/users
Content-Type: application/json

### List Users with Pagination
GET {{baseUrl}}/api/v1/users?limit=5&offset=0
Content-Type: application/json

### Create Multiple Users for Testing
POST {{baseUrl}}/api/v1/users
Content-Type: application/json

{
  "email": "alice@example.com",
  "name": "Alice Smith"
}

###

POST {{baseUrl}}/api/v1/users
Content-Type: application/json

