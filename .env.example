# Application settings
APP_HOST=localhost
APP_PORT=8080

# CORS allowed origins (comma-separated)
# Use appropriate origins for your frontend in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT secret key for signing tokens (required — generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h

# Logging
# Level: debug, info, warn, error (default: info)
LOG_LEVEL=debug
# Format: text (human-readable) or json (machine-parseable, use in production)
LOG_FORMAT=text

# Gin mode: debug (default) or release (production)
GIN_MODE=debug

# Database Configuration
# Use DB_HOST=localhost when running app locally (make app-start)
# Use DB_HOST=postgres when running in Docker
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres123
DB_NAME=microservice_db

# Rate limiting (required — no defaults)
# Use generous values for dev/test; stricter values in production (e.g. 100 req/min per IP).
RATE_LIMIT_IP_MAX=10000
RATE_LIMIT_IP_WINDOW=1m
RATE_LIMIT_USER_MAX=10000
RATE_LIMIT_USER_WINDOW=1m

# Login throttle (required — no defaults)
LOGIN_THROTTLE_MAX_ATTEMPTS=100
LOGIN_THROTTLE_WINDOW=1m
LOGIN_THROTTLE_LOCKOUT=1m

# Schemathesis (contract testing) — used by make test-contract
# Defaults match seed data from test/seed.sql
ST_API_HOST=localhost
ST_API_PORT=8080
ST_AUTH_EMAIL=alice@ductifact.dev
ST_AUTH_PASSWORD=password123