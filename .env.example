# Application settings
APP_HOST=localhost
APP_PORT=8080

# CORS allowed origins (comma-separated)
# Use appropriate origins for your frontend in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT secret key for signing tokens (required — generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h

# Logging
# Level: debug, info, warn, error (default: info)
LOG_LEVEL=debug
# Format: text (human-readable) or json (machine-parseable, use in production)
LOG_FORMAT=text

# Gin mode: debug (default) or release (production)
GIN_MODE=debug

# Database Configuration
# Use DB_HOST=localhost when running app locally (make app-start)
# Use DB_HOST=postgres when running in Docker
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres123
DB_NAME=microservice_db

# Rate limiting (required — no defaults)
# Use generous values for dev/test; stricter values in production (e.g. 100 req/min per IP).
RATE_LIMIT_IP_MAX=10000
RATE_LIMIT_IP_WINDOW=1m
RATE_LIMIT_USER_MAX=10000
RATE_LIMIT_USER_WINDOW=1m

# Login throttle (required — no defaults)
LOGIN_THROTTLE_MAX_ATTEMPTS=100
LOGIN_THROTTLE_WINDOW=1m
LOGIN_THROTTLE_LOCKOUT=1m

# MinIO (S3-compatible object storage for images)
# Use MINIO_HOST=localhost when running app locally
# Use MINIO_HOST=minio when running in Docker
# Use MINIO_USE_SSL=false when running locally without SSL; set to true in production with proper SSL setup.
MINIO_HOST=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ductifact
MINIO_USE_SSL=false

# SMTP / Email
# In development, defaults point to MailPit (local SMTP server in docker-compose).
# In production, set SMTP_AUTH=true and use your real provider (SendGrid, SES, etc.).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_AUTH=false
SMTP_USERNAME=noop
SMTP_PASSWORD=noop
SMTP_FROM=noreply@ductifact.com

# One-time tokens (email verification, password reset)
# VERIFICATION_BASE_URL is the base URL used to build verification links in emails.
# Works with web apps and mobile apps (via Universal Links / App Links).
VERIFICATION_BASE_URL=http://localhost:3000
VERIFICATION_EMAIL_TOKEN_TTL=24h
VERIFICATION_PASSWORD_RESET_TOKEN_TTL=1h